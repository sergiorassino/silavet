APP_NAME=SILAVET
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Argentina/Buenos_Aires
# Puertos 8001 / 5174 para convivir con Sistemas Escolares (8000 / 5173) en la misma PC
APP_URL=http://127.0.0.1:8001
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# Identificador del laboratorio (tenant)
TENANT_SLUG=neolab

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
# Mismo puerto/credenciales que Sistemas Escolares si comparten WAMP (ej. 3307)
DB_PORT=3307
# SILAVET usa prefijo lb_ (legacy NeoLab). NO usar ia_ (eso es de colegios).
DB_DATABASE=lb_neolab
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="laboratorio@ejemplo.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Producción con subcarpeta (ejemplo):
# APP_URL=https://dominio.com/lab/neolab
# SESSION_SECURE_COOKIE=true
