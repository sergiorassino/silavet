{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Dev: Laravel + Vite (SILAVET)",
            "type": "shell",
            "command": "npm run dev:all",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "custom",
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "(Development Server \\(http://127\\.0\\.0\\.1:8001\\)|Local:\\s+http://127\\.0\\.0\\.1:5174|ready in \\d+ ms)"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            }
        }
    ]
}
